# Anthropic (required)
ANTHROPIC_API_KEY=sk-ant-...

# Polymarket CLOB API (optional — for live trading)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=

# Twitter API v2 (optional — real-time news stream)
TWITTER_BEARER_TOKEN=

# Telegram Bot (optional — channel monitoring)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_IDS=

# NewsAPI.org (optional — broader news coverage)
NEWSAPI_KEY=

# Pipeline Settings
DRY_RUN=true
MAX_BET_USD=25
# Caps total notional deployed per day, not realized losses
DAILY_SPEND_LIMIT_USD=100
EDGE_THRESHOLD=0.10

# Price-room guards (edge.detect_edge_v2): skip signals priced outside the band
# where the direction has historically paid.
# Bullish (YES): min raised from 0.05 to 0.12 — markets under 0.15 grade only
# 5.8% accurate (longshot lottery tickets); max tightened from 0.85 to 0.82
# (little room left to profit above it).
BULLISH_MIN_PRICE=0.12
BULLISH_MAX_PRICE=0.82
# Bearish (NO): min 0.18 — NO bets on very low-priced markets are risky; max
# kept wide at 0.88 since good NO edge exists in the 0.87-0.93 range.
BEARISH_MIN_PRICE=0.18
BEARISH_MAX_PRICE=0.88

# V2 Settings
MAX_VOLUME_USD=500000
MIN_VOLUME_USD=1000
SPEED_TARGET_SECONDS=5

# Freshness gate: trade only on news younger than these source-specific limits
# (seconds). Real-time feeds (Twitter) get a tight window; slower aggregators
# (RSS/NewsAPI) get more slack. MAX_NEWS_AGE_SECONDS is the fallback for
# unknown/unlisted sources.
MAX_NEWS_AGE_SECONDS=900
MAX_NEWS_AGE_SECONDS_TWITTER=900
MAX_NEWS_AGE_SECONDS_RSS=7200
MAX_NEWS_AGE_SECONDS_NEWSAPI=14400
MAX_NEWS_AGE_SECONDS_TELEGRAM=1800

# Direction-specific materiality floors (calibration-tuned: bearish accuracy is
# much lower than bullish, so bearish needs a higher bar)
MATERIALITY_THRESHOLD_BULLISH=0.3
MATERIALITY_THRESHOLD_BEARISH=0.4

# High-materiality confirmation gate: signals at/above HIGH_MATERIALITY_THRESHOLD
# need the same direction from MIN_CONFIRMING_SOURCES distinct sources within
# CONFIRMATION_WINDOW_HOURS, else they're held (action=needs_confirmation)
HIGH_MATERIALITY_THRESHOLD=0.5
CONFIRMATION_WINDOW_HOURS=2
MIN_CONFIRMING_SOURCES=2

# Event context: markets sharing a Gamma event_id are sibling outcomes. Cap how
# many positions may be open across one event (mutually-exclusive outcomes are
# highly correlated). 1 = one position per event.
MAX_POSITIONS_PER_EVENT=1

# Whale tracking: comma-separated wallet addresses to shadow. When a whale opens
# a position on a niche market we missed, the pipeline investigates it. Leave
# empty to disable. The remaining knobs tune polling cadence and thresholds.
WHALE_WALLETS=
WHALE_CHECK_INTERVAL_MINUTES=15
WHALE_LOOKBACK_MINUTES=30
WHALE_COOLDOWN_HOURS=6
WHALE_MIN_TRADE_USD=1000

# Re-entry: after a non-resolution close, keep watching the market for
# REENTRY_WATCH_HOURS and re-enter (at most MAX_REENTRY_PER_MARKET times) when a
# new classification reverses the exit thesis. A news-close re-enters at
# materiality >= REENTRY_NEWS_MATERIALITY on the original side; a stop-loss close
# is stricter (>= REENTRY_SL_MATERIALITY and >= REENTRY_SL_MIN_SOURCES sources);
# a take-profit close never re-enters.
REENTRY_WATCH_HOURS=72
MAX_REENTRY_PER_MARKET=1
REENTRY_NEWS_MATERIALITY=0.45
REENTRY_SL_MATERIALITY=0.55
REENTRY_SL_MIN_SOURCES=2

# Circuit breaker: auto-pause trading when recent realized performance
# deteriorates. Trips when the rolling 7-day drawdown exceeds CIRCUIT_BREAKER_DD
# (fraction of peak) or the 7-day daily Sharpe falls below CIRCUIT_BREAKER_SHARPE.
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_DD=0.20
CIRCUIT_BREAKER_SHARPE=-1.0
# Set to ISO date (2026-06-14) to ignore positions closed before this date
CIRCUIT_BREAKER_START_DATE=

# Dashboard
# Set to ISO date (2026-06-14) to hide old test positions from dashboard
DASHBOARD_POSITIONS_START_DATE=
# Set to ISO date (2026-06-14) to count only positions opened on/after it in the
# dashboard performance panel (closed count, win rate, PnL, deployed capital)
PERFORMANCE_START_DATE=
