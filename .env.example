# Anthropic (required)
ANTHROPIC_API_KEY=sk-ant-...

# Polymarket CLOB API (optional — for live trading)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=

# Twitter API v2 (optional — real-time news stream)
TWITTER_BEARER_TOKEN=

# Telegram Bot (optional — channel monitoring)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_IDS=

# NewsAPI.org (optional — broader news coverage)
NEWSAPI_KEY=

# Pipeline Settings
DRY_RUN=true
MAX_BET_USD=25
DAILY_LOSS_LIMIT_USD=100
EDGE_THRESHOLD=0.10

# V2 Settings
MAX_VOLUME_USD=500000
MIN_VOLUME_USD=1000
SPEED_TARGET_SECONDS=5

# Direction-specific materiality floors (calibration-tuned: bearish accuracy is
# much lower than bullish, so bearish needs a higher bar)
MATERIALITY_THRESHOLD_BULLISH=0.3
MATERIALITY_THRESHOLD_BEARISH=0.4

# High-materiality confirmation gate: signals at/above HIGH_MATERIALITY_THRESHOLD
# need the same direction from MIN_CONFIRMING_SOURCES distinct sources within
# CONFIRMATION_WINDOW_HOURS, else they're held (action=needs_confirmation)
HIGH_MATERIALITY_THRESHOLD=0.5
CONFIRMATION_WINDOW_HOURS=2
MIN_CONFIRMING_SOURCES=2
